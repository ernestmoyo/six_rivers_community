<mxfile host="app.diagrams.net" modified="2026-03-25T00:00:00.000Z" agent="Claude" version="21.0.0">
  <diagram id="methodology" name="Methodology Overview">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Community Intelligence Platform — Methodology" style="text;html=1;fontSize=24;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1e3a5f;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="1000" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Bridging field operations and data-driven conservation" style="text;html=1;fontSize=14;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="400" y="65" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- Phase 1: Listen -->
        <mxCell id="p1_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#e8f5e9;strokeColor=#4a7c59;strokeWidth=2;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="280" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="p1_num" value="01" style="text;html=1;fontSize=36;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#4a7c5940;" vertex="1" parent="1">
          <mxGeometry x="55" y="130" width="60" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p1_title" value="LISTEN" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#2e7d32;" vertex="1" parent="1">
          <mxGeometry x="40" y="175" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p1_desc" value="&lt;div style='text-align:left;padding:8px;font-size:12px;'&gt;&#xa;• Met with field team (Lilian, Justina, Irene, Mary, Edna)&lt;br/&gt;&#xa;• Understood operational reality:&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Work OUTSIDE parks with villages&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Small farms (≤0.4 ha)&lt;br/&gt;&amp;nbsp;&amp;nbsp;– 3-month crop cycles&lt;br/&gt;• Identified key challenges:&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Elephant crop raids (Ifakara)&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Cattle pressure (Mbarali)&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Dry-season seedling losses&lt;br/&gt;• Reviewed farming presentation&lt;br/&gt;• Mapped 21 real villages across 2 districts&lt;/div&gt;" style="text;html=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="45" y="210" width="270" height="240" as="geometry"/>
        </mxCell>

        <!-- Phase 2: Design -->
        <mxCell id="p2_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#e3f2fd;strokeColor=#1565c0;strokeWidth=2;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="120" width="280" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="p2_num" value="02" style="text;html=1;fontSize=36;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1565c040;" vertex="1" parent="1">
          <mxGeometry x="375" y="130" width="60" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p2_title" value="DESIGN" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="360" y="175" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p2_desc" value="&lt;div style='text-align:left;padding:8px;font-size:12px;'&gt;&#xa;• Four farming approach modules:&lt;br/&gt;&amp;nbsp;&amp;nbsp;1. Chilli Fencing (deterrence)&lt;br/&gt;&amp;nbsp;&amp;nbsp;2. Agroforestry (tree-crop mix)&lt;br/&gt;&amp;nbsp;&amp;nbsp;3. Shambachungu (group farming)&lt;br/&gt;&amp;nbsp;&amp;nbsp;4. Horticulture (vegetables)&lt;br/&gt;&amp;nbsp;&amp;nbsp;5. Tree Nurseries (restoration)&lt;br/&gt;• Geographic structure:&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Ifakara TC (13 villages)&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Mbarali DC (8 villages)&lt;br/&gt;• Wildlife incident tracking&lt;br/&gt;• Seasonal awareness&lt;br/&gt;&amp;nbsp;&amp;nbsp;(dry-season failure patterns)&lt;br/&gt;• Impact reporting for donors&lt;/div&gt;" style="text;html=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="365" y="210" width="270" height="240" as="geometry"/>
        </mxCell>

        <!-- Phase 3: Build -->
        <mxCell id="p3_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff8e1;strokeColor=#f9a825;strokeWidth=2;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="120" width="280" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="p3_num" value="03" style="text;html=1;fontSize=36;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#f9a82540;" vertex="1" parent="1">
          <mxGeometry x="695" y="130" width="60" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p3_title" value="BUILD" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#f57f17;" vertex="1" parent="1">
          <mxGeometry x="680" y="175" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p3_desc" value="&lt;div style='text-align:left;padding:8px;font-size:12px;'&gt;&#xa;• Next.js web application&lt;br/&gt;&amp;nbsp;&amp;nbsp;(works on phone + desktop)&lt;br/&gt;• Mapbox GL JS interactive maps&lt;br/&gt;&amp;nbsp;&amp;nbsp;(satellite + terrain views)&lt;br/&gt;• Real village data, real names&lt;br/&gt;• Dashboard with live KPIs:&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Farmers, seedlings, survival&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Chilli fences, deterrence rate&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Wildlife incidents&lt;br/&gt;• Offline-capable (PWA)&lt;br/&gt;• Donor report generation&lt;br/&gt;• Climate/seasonal data&lt;br/&gt;• Cattle pressure monitoring&lt;/div&gt;" style="text;html=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="685" y="210" width="270" height="240" as="geometry"/>
        </mxCell>

        <!-- Phase 4: Iterate -->
        <mxCell id="p4_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fce4ec;strokeColor=#c62828;strokeWidth=2;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="120" width="280" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="p4_num" value="04" style="text;html=1;fontSize=36;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#c6282840;" vertex="1" parent="1">
          <mxGeometry x="1015" y="130" width="60" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4_title" value="ITERATE" style="text;html=1;fontSize=18;fontStyle=1;align=center;fillColor=none;strokeColor=none;fontColor=#c62828;" vertex="1" parent="1">
          <mxGeometry x="1000" y="175" width="280" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p4_desc" value="&lt;div style='text-align:left;padding:8px;font-size:12px;'&gt;&#xa;• Present demo to field team&lt;br/&gt;• Gather feedback on:&lt;br/&gt;&amp;nbsp;&amp;nbsp;– What's useful vs. missing?&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Data collection workflows&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Connectivity constraints&lt;br/&gt;• Priority next steps:&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Database + authentication&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Mobile data entry forms&lt;br/&gt;&amp;nbsp;&amp;nbsp;– GPS integration for fences&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Automated donor PDF reports&lt;br/&gt;&amp;nbsp;&amp;nbsp;– Swahili language support&lt;br/&gt;• Deploy to production (Vercel)&lt;/div&gt;" style="text;html=1;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1005" y="210" width="270" height="240" as="geometry"/>
        </mxCell>

        <!-- Arrows between phases -->
        <mxCell id="arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#4a7c59;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="p1_box" target="p2_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565c0;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="p2_box" target="p3_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#f9a825;strokeWidth=2;endArrow=blockThin;endFill=1;" edge="1" source="p3_box" target="p4_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Feedback loop arrow -->
        <mxCell id="feedback" value="Continuous Feedback Loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#c62828;strokeWidth=2;dashed=1;endArrow=blockThin;endFill=1;fontColor=#c62828;fontSize=11;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="p4_box" target="p1_box" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1140" y="500"/>
              <mxPoint x="180" y="500"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Bottom bar -->
        <mxCell id="bottom_bar" value="" style="rounded=1;fillColor=#1e3a5f;strokeColor=none;arcSize=20;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="1240" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bottom_text" value="Community-centered  •  Data-driven  •  Built for the field  •  Honest about what works" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="40" y="545" width="1240" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
