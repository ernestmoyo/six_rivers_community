// Six Rivers Community Intelligence Platform — Prisma schema
//
// REFACTORED 2026-05-16: additive-only against the existing Supabase DB.
//
// The existing Supabase project already holds 14 tables managed via the SQL
// editor (field_visits, cattle_incidents, agroforestry_plots, crop_cycles,
// iga_financial_updates, radio_sessions, survival_check_submissions, plus
// the srata_* cluster). Those tables ARE NOT modelled here — the existing
// app code talks to them via @/lib/supabase. This schema is ONLY for the
// new M&E spine (Phase 1+) and is designed to add cleanly alongside them
// with no ALTER TABLE on any existing row.
//
// Officer identity is `officerId` (text) everywhere — matching the existing
// `officer_id` columns on field_visits / agroforestry_plots / etc. There is
// no `users` table in Supabase; device-PIN auth lives entirely in IndexedDB.
//
// PostGIS Geography columns are added via Unsupported() so they exist in
// the DB; queries on them use prisma.$queryRaw or PostGIS functions.

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ─── Canonical geography (new, empty until shapefile seed) ─────────
//
// These four tables hold the canonical Tanzania administrative hierarchy
// from the official shapefiles. They start empty; OperationalLocation
// rows can FK into them once the shapefile data is imported via a future
// scripts/seed-shapefiles.ts. The existing data tables (field_visits,
// cattle_incidents, etc.) use denormalized village_id+village_name and
// do NOT need to reference these.

model Region {
  id         Int        @id @default(autoincrement())
  name       String
  population Int?
  districts  District[]

  @@map("regions")
}

model District {
  id         Int    @id @default(autoincrement())
  name       String
  regionId   Int    @map("region_id")
  region     Region @relation(fields: [regionId], references: [id])
  population Int?
  wards      Ward[]

  @@map("districts")
}

model Ward {
  id                   Int                   @id @default(autoincrement())
  name                 String
  districtId           Int                   @map("district_id")
  district             District              @relation(fields: [districtId], references: [id])
  population           Int?
  villages             Village[]
  operationalLocations OperationalLocation[]

  @@map("wards")
}

model Village {
  id                   Int                   @id @default(autoincrement())
  name                 String
  wardId               Int                   @map("ward_id")
  ward                 Ward                  @relation(fields: [wardId], references: [id])
  isOperational        Boolean               @default(false) @map("is_operational")
  sector               String? // 'msolwa' | 'usangu'
  distanceToNpKm       Float?                @map("distance_to_np_km")
  operationalLocations OperationalLocation[]

  @@map("villages")
}

// ─── Operational locations (what the team actually calls places) ─────

enum OperationalLocationKind {
  village
  ward
  hamlet
}

enum ReconciliationStatus {
  matched
  alias_override
  missing_in_shapefile
  decommissioned
  split_disputed
  pending
}

model OperationalLocation {
  id                   Int                                    @id @default(autoincrement())
  kind                 OperationalLocationKind
  displayName          String                                 @map("display_name")
  canonicalVillageId   Int?                                   @map("canonical_village_id")
  canonicalVillage     Village?                               @relation(fields: [canonicalVillageId], references: [id])
  canonicalWardId      Int?                                   @map("canonical_ward_id")
  canonicalWard        Ward?                                  @relation(fields: [canonicalWardId], references: [id])
  aliases              String[]                               @default([])
  reconciliationStatus ReconciliationStatus                   @default(pending) @map("reconciliation_status")
  notes                String?
  lat                  Float?
  lng                  Float?
  // PostGIS Geography(Point,4326) — populated from lat/lng via trigger
  geom                 Unsupported("geography(Point, 4326)")?
  isOperational        Boolean                                @default(true) @map("is_operational")
  sector               String? // 'msolwa' | 'usangu' | 'outreach'
  createdByOfficerId   String?                                @map("created_by_officer_id")
  reviewedByOfficerId  String?                                @map("reviewed_by_officer_id")
  reviewedAt           DateTime?                              @map("reviewed_at")
  createdAt            DateTime                               @default(now()) @map("created_at")
  updatedAt            DateTime                               @updatedAt @map("updated_at")

  persons         Person[]
  groups          Group[]
  schools         School[]
  formSubmissions FormSubmission[]

  @@index([reconciliationStatus])
  @@index([sector])
  @@map("operational_locations")
}

// ─── Programme taxonomy ──────────────────────────────────────────────

enum BeneficiaryKind {
  individual
  group
  school
  mixed
}

enum SectorScope {
  msolwa
  usangu
  both
  outreach
}

model Pillar {
  id          Int              @id @default(autoincrement())
  code        String           @unique
  name        String
  description String?
  isActive    Boolean          @default(true) @map("is_active")
  placeholder Boolean          @default(false)
  orderIndex  Int              @default(0) @map("order_index")
  programmes  Programme[]
  tocs        TheoryOfChange[]

  @@map("pillars")
}

model Programme {
  id            Int              @id @default(autoincrement())
  code          String           @unique
  name          String
  description   String?
  pillarId      Int              @map("pillar_id")
  pillar        Pillar           @relation(fields: [pillarId], references: [id])
  orderIndex    Int              @default(0) @map("order_index")
  subprogrammes Subprogramme[]
  tocs          TheoryOfChange[]
  indicators    Indicator[]

  @@map("programmes")
}

model Subprogramme {
  id          Int        @id @default(autoincrement())
  code        String     @unique
  name        String
  description String?
  programmeId Int        @map("programme_id")
  programme   Programme  @relation(fields: [programmeId], references: [id])
  orderIndex  Int        @default(0) @map("order_index")
  activities  Activity[]

  @@map("subprogrammes")
}

model Activity {
  id              Int               @id @default(autoincrement())
  code            String            @unique
  name            String
  description     String?
  subprogrammeId  Int               @map("subprogramme_id")
  subprogramme    Subprogramme      @relation(fields: [subprogrammeId], references: [id])
  beneficiaryKind BeneficiaryKind   @map("beneficiary_kind")
  sectorScope     SectorScope       @map("sector_scope")
  startYear       Int?              @map("start_year")
  endYear         Int?              @map("end_year")
  isActive        Boolean           @default(true) @map("is_active")
  orderIndex      Int               @default(0) @map("order_index")
  variants        ActivityVariant[]
  groups          Group[]
  enrollments     Enrollment[]
  formSchemas     FormSchema[]
  indicators      Indicator[]

  @@map("activities")
}

model ActivityVariant {
  id         Int      @id @default(autoincrement())
  code       String
  label      String
  note       String?
  activityId Int      @map("activity_id")
  activity   Activity @relation(fields: [activityId], references: [id])
  orderIndex Int      @default(0) @map("order_index")

  @@unique([activityId, code])
  @@map("activity_variants")
}

// ─── Beneficiary spine ───────────────────────────────────────────────

model Person {
  id                    Int                  @id @default(autoincrement())
  fullName              String               @map("full_name")
  sex                   String? // 'female' | 'male' | 'other'
  dob                   DateTime?            @db.Date
  age                   Int?
  phone                 String?
  nationalId            String?              @map("national_id")
  schoolClass           String?              @map("school_class")
  operationalLocationId Int?                 @map("operational_location_id")
  operationalLocation   OperationalLocation? @relation(fields: [operationalLocationId], references: [id])
  /// SHA-256 hash of (fullName + dob + guardianPhone) — soft dedup key
  dedupHash             String               @unique @map("dedup_hash")
  demographicsJson      Json?                @map("demographics_json")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  enrollments      Enrollment[]
  groupMemberships GroupMembership[]
  formSubmissions  FormSubmission[]
  studentAccount   StudentAccount?

  @@index([fullName])
  @@map("persons")
}

model School {
  id                    Int                 @id @default(autoincrement())
  name                  String
  operationalLocationId Int                 @map("operational_location_id")
  operationalLocation   OperationalLocation @relation(fields: [operationalLocationId], references: [id])
  level                 String? // 'primary' | 'secondary' | 'mixed'
  headTeacher           String?             @map("head_teacher")
  contactPhone          String?             @map("contact_phone")
  createdAt             DateTime            @default(now()) @map("created_at")

  enrollments Enrollment[]

  @@map("schools")
}

enum GroupStatus {
  active
  struggling
  dormant
  closed
}

model Group {
  id                    Int                  @id @default(autoincrement())
  activityId            Int                  @map("activity_id")
  activity              Activity             @relation(fields: [activityId], references: [id])
  name                  String
  operationalLocationId Int?                 @map("operational_location_id")
  operationalLocation   OperationalLocation? @relation(fields: [operationalLocationId], references: [id])
  formedAt              DateTime?            @map("formed_at") @db.Date
  status                GroupStatus          @default(active)
  sector                String?
  leaderPersonId        Int?                 @map("leader_person_id")
  notes                 String?
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")

  memberships  GroupMembership[]
  transactions GroupTransaction[]
  enrollments  Enrollment[]

  @@index([activityId])
  @@index([status])
  @@map("groups")
}

model GroupMembership {
  id        Int       @id @default(autoincrement())
  groupId   Int       @map("group_id")
  group     Group     @relation(fields: [groupId], references: [id])
  personId  Int       @map("person_id")
  person    Person    @relation(fields: [personId], references: [id])
  joinedAt  DateTime  @map("joined_at") @db.Date
  leftAt    DateTime? @map("left_at") @db.Date
  role      String?
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([groupId])
  @@index([personId])
  @@map("group_memberships")
}

enum EnrollmentStatus {
  enrolled
  active
  graduated
  dropped_out
  transferred
  withdrawn
}

model Enrollment {
  id                 Int              @id @default(autoincrement())
  activityId         Int              @map("activity_id")
  activity           Activity         @relation(fields: [activityId], references: [id])
  cohortYear         Int              @map("cohort_year")
  personId           Int?             @map("person_id")
  person             Person?          @relation(fields: [personId], references: [id])
  groupId            Int?             @map("group_id")
  group              Group?           @relation(fields: [groupId], references: [id])
  schoolId           Int?             @map("school_id")
  school             School?          @relation(fields: [schoolId], references: [id])
  status             EnrollmentStatus @default(enrolled)
  startedAt          DateTime         @default(now()) @map("started_at") @db.Date
  endedAt            DateTime?        @map("ended_at") @db.Date
  exitReason         String?          @map("exit_reason")
  exitReasonCategory String?          @map("exit_reason_category")
  metaJson           Json?            @map("meta_json")
  syncedFromFormId   Int?             @map("synced_from_form_id")
  syncedFromForm     FormSubmission?  @relation(fields: [syncedFromFormId], references: [id])
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([activityId, cohortYear, personId, groupId, schoolId])
  @@index([activityId, cohortYear])
  @@index([status, cohortYear])
  @@map("enrollments")
}

enum TransactionKind {
  capital
  revenue
  expense
  distribution
}

model GroupTransaction {
  id                  Int             @id @default(autoincrement())
  groupId             Int             @map("group_id")
  group               Group           @relation(fields: [groupId], references: [id])
  periodYearMonth     String          @map("period_year_month") // 'YYYY-MM'
  kind                TransactionKind
  amountTSh           Decimal         @map("amount_tsh") @db.Decimal(14, 2)
  category            String?
  narrative           String?
  recordedByOfficerId String?         @map("recorded_by_officer_id")
  recordedAt          DateTime        @default(now()) @map("recorded_at")

  @@index([groupId, periodYearMonth])
  @@index([periodYearMonth])
  @@map("group_transactions")
}

// ─── Forms (Kobo mirror) ─────────────────────────────────────────────

model FormSchema {
  id          Int       @id @default(autoincrement())
  activityId  Int?      @map("activity_id")
  activity    Activity? @relation(fields: [activityId], references: [id])
  koboFormUid String?   @map("kobo_form_uid")
  version     String
  title       String
  schemaJson  Json      @map("schema_json")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  submissions FormSubmission[]

  @@unique([activityId, version])
  @@index([koboFormUid])
  @@map("form_schemas")
}

model FormSubmission {
  id                    Int                                    @id @default(autoincrement())
  formSchemaId          Int                                    @map("form_schema_id")
  formSchema            FormSchema                             @relation(fields: [formSchemaId], references: [id])
  personId              Int?                                   @map("person_id")
  person                Person?                                @relation(fields: [personId], references: [id])
  operationalLocationId Int?                                   @map("operational_location_id")
  operationalLocation   OperationalLocation?                   @relation(fields: [operationalLocationId], references: [id])
  payloadJson           Json                                   @map("payload_json")
  gpsLat                Float?                                 @map("gps_lat")
  gpsLng                Float?                                 @map("gps_lng")
  geom                  Unsupported("geography(Point, 4326)")?
  submittedByOfficerId  String?                                @map("submitted_by_officer_id")
  submittedAt           DateTime                               @default(now()) @map("submitted_at")
  syncedAt              DateTime?                              @map("synced_at")
  /// Idempotency key — set by the client offline queue. Matches the existing
  /// `client_submission_id` pattern used by field_visits / cattle_incidents.
  idempotencyKey        String?                                @unique @map("idempotency_key")

  enrollments Enrollment[]

  @@index([formSchemaId])
  @@index([submittedAt])
  @@map("form_submissions")
}

// ─── Theory of Change ────────────────────────────────────────────────

enum TocScope {
  pillar
  programme
}

enum TocLevel {
  input
  activity
  output
  outcome
  impact
}

model TheoryOfChange {
  id          Int        @id @default(autoincrement())
  scope       TocScope
  pillarId    Int?       @map("pillar_id")
  pillar      Pillar?    @relation(fields: [pillarId], references: [id])
  programmeId Int?       @map("programme_id")
  programme   Programme? @relation(fields: [programmeId], references: [id])
  version     String
  title       String
  narrative   String?
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  nodes TocNode[]

  @@unique([scope, pillarId, programmeId, version])
  @@map("theories_of_change")
}

model TocNode {
  id         Int            @id @default(autoincrement())
  tocId      Int            @map("toc_id")
  toc        TheoryOfChange @relation(fields: [tocId], references: [id])
  code       String
  level      TocLevel
  statement  String
  note       String?
  parentId   Int?           @map("parent_id")
  parent     TocNode?       @relation("TocNodeParent", fields: [parentId], references: [id])
  children   TocNode[]      @relation("TocNodeParent")
  orderIndex Int            @default(0) @map("order_index")
  createdAt  DateTime       @default(now()) @map("created_at")

  indicators Indicator[]

  @@unique([tocId, code])
  @@index([level])
  @@map("toc_nodes")
}

// ─── Indicators ──────────────────────────────────────────────────────

enum IndicatorComputation {
  manual
  derived
}

enum IndicatorPeriodKind {
  year
  quarter
  month
}

enum IndicatorSource {
  auto
  manual
}

model Indicator {
  id             Int                  @id @default(autoincrement())
  code           String               @unique
  name           String
  description    String?
  level          TocLevel
  unit           String // 'count' | 'percent' | 'ha' | 'TSh' | 'kg' | 'km' | ...
  disaggregateBy String[]             @default([]) @map("disaggregate_by")
  computation    IndicatorComputation @default(manual)
  derivedQuery   String?              @map("derived_query")
  tocNodeId      Int?                 @map("toc_node_id")
  tocNode        TocNode?             @relation(fields: [tocNodeId], references: [id])
  /// String code of the TocNode this indicator targets (resolved to tocNodeId
  /// during seeding). Kept here for traceability so a future seed re-link is
  /// easy even if TocNode ids change.
  tocNodeCode    String?              @map("toc_node_code")
  programmeId    Int?                 @map("programme_id")
  programme      Programme?           @relation(fields: [programmeId], references: [id])
  activityId     Int?                 @map("activity_id")
  activity       Activity?            @relation(fields: [activityId], references: [id])
  isActive       Boolean              @default(true) @map("is_active")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  periods IndicatorPeriod[]

  @@index([level])
  @@index([programmeId])
  @@index([activityId])
  @@map("indicators")
}

model IndicatorPeriod {
  id                 Int                 @id @default(autoincrement())
  indicatorId        Int                 @map("indicator_id")
  indicator          Indicator           @relation(fields: [indicatorId], references: [id])
  periodKind         IndicatorPeriodKind @map("period_kind")
  periodKey          String              @map("period_key") // 'YYYY' | 'YYYY-Qn' | 'YYYY-MM'
  target             Decimal?            @db.Decimal(18, 4)
  actual             Decimal?            @db.Decimal(18, 4)
  source             IndicatorSource     @default(auto)
  disaggregationJson Json?               @map("disaggregation_json")
  updatedByOfficerId String?             @map("updated_by_officer_id")
  computedAt         DateTime?           @map("computed_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@unique([indicatorId, periodKind, periodKey])
  @@index([periodKey])
  @@map("indicator_periods")
}

// ─── Student portal (Phase 3) ────────────────────────────────────────

enum StudentAccountStatus {
  pending
  approved
  suspended
}

model StudentAccount {
  id                  Int                  @id @default(autoincrement())
  personId            Int                  @unique @map("person_id")
  person              Person               @relation(fields: [personId], references: [id])
  email               String               @unique
  passwordHash        String               @map("password_hash")
  status              StudentAccountStatus @default(pending)
  approvedByOfficerId String?              @map("approved_by_officer_id")
  approvedAt          DateTime?            @map("approved_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  lastLoginAt         DateTime?            @map("last_login_at")

  @@index([status])
  @@map("student_accounts")
}
